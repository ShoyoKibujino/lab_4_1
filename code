# Родительский класс
class PerformanceMetric:

    """Базовый класс для метрик производительности
        Атрибуты: name (имя метрики)
                  sla (соглашение об уровне обслуживания)
        Методы: (магический, конструктор) init (создает и инициализирует объект)
                (магический) srt (возвращает строковое представление объекта для отображения пользователю)
                (обычный) evaluate_performance (оценивает производительность)
    """

    def __init__(self, name, sla):
        self.name = name
        self.sla = sla

    def __str__(self):
        return f"{self.name}: SLA = {self.sla}%" # Возвращает строку с данными

    def evaluate_performance(self):
        """Метод для оценки производительности (будет переопределен)"""
        pass # ПУСТАЯ РЕАЛИЗАЦИЯ - будет переопределен в наследнике

# Дочерний класс
# НАСЛЕДОВАНИЕ (Создание нового класса на основе существующего, с добавлением или переопределением функциональности)
class SupportMetric(PerformanceMetric): # класс наследует от PerformanceMetric

    """Класс для метрик поддержки
        Атрибуты: name (имя метрики)
                  sla (соглашение об уровне обслуживания)
                  department (название отдела, к которому относится метрика)
        Методы: (магический, конструктор) init (создает и инициализирует объект)
                (магический) srt (возвращает строковое представление объекта для отображения пользователю)
                (обычный) evaluate_performance (оценивает производительность)
        """

    def __init__(self, name, sla, department):
        super().__init__(name, sla) # ВЫЗОВ КОНСТРУКТОРА РОДИТЕЛЯ - передаем name и sla
        self.department = department # НОВЫЙ АТРИБУТ - только для SupportMetric

    def __str__(self): # ПЕРЕОПРЕДЕЛЕНИЕ метода родителя
        return f"{self.name} (Отдел: {self.department}): SLA = {self.sla}%" # Возвращает форматированную строку с информацией об объекте

    def evaluate_performance(self): # ПЕРЕОПРЕДЕЛЕННЫЙ МЕТОД (ПОЛИМОРФИЗМ)
        """Переопределенный метод оценки производительности"""
        return self.sla # ВОЗВРАЩАЕТ ЗНАЧЕНИЕ SLA (в родителе был pass)

# БАЗОВЫЙ КЛАСС 1 ТАРИФ
# ИНКАПСУЛЯЦИЯ (Скрытие внутренней реализации объекта и предоставление доступа только через методы)
class TariffPlan:

    """Тарифный план
        Атрибуты: name (название тарифа)
                  monthly_fee (абонентская плата)
                  data_limit (лимит трафика)
                  call_minutes (минуты разговора)
        Методы: (магический, конструктор) init (создает и инициализирует объект)
                (магический) srt (возвращает строковое представление объекта для отображения пользователю)
                (обычный) calculate_cost (расчет стоимости)
        """

    def __init__(self, name, monthly_fee, data_limit, call_minutes):
    # Данные скрыты внутри объекта, эти атрибуты нельзя изменить напрямую, только через создание нового объекта
        self.name = name
        self.monthly_fee = monthly_fee
        self.data_limit = data_limit
        self.call_minutes = call_minutes

    def __str__(self):
        return (f"Тариф: {self.name}\n" # многострочный возврат
                f"Абонентская плата: {self.monthly_fee} руб.\n"
                f"Лимит трафика: {self.data_limit} ГБ\n"
                f"Минуты разговора: {self.call_minutes} мин.")

    def calculate_cost(self, extra_data=0, extra_calls=0):
        """Расчет стоимости с учетом дополнительных услуг"""
        # Внутренняя логика расчета скрыта внутри метода
        extra_cost = (extra_data * 50) + (extra_calls * 2)  # вычисление доп стоимости
        return self.monthly_fee + extra_cost # возвращает общую стоимость
        # Пользователь не знает, как именно считается стоимость

# БАЗОВЫЙ КЛАСС 2 СУБЪЕКТ
class Subscriber:

    """Абонент
        Атрибуты: phone_number (номер телефона)
                  full_name (ФИО)
                  tariff_plan (объект класса TariffPlan)
                  balance (баланс)
        Методы: (магический, конструктор) init (создает и инициализирует объект)
                (магический) srt (возвращает строковое представление объекта для отображения пользователю)
                (обычный) top_up_balance (пополнение баланса)
                (обычный) check_balance (проверка баланса)
    """

    def __init__(self, phone_number, full_name, tariff_plan, balance=0):
        self.phone_number = phone_number
        self.full_name = full_name
        self.tariff_plan = tariff_plan
        self.balance = balance

    def __str__(self):
        return (f"Абонент: {self.full_name}\n"
                f"Номер: {self.phone_number}\n"
                f"Тариф: {self.tariff_plan.name}\n" # доступ к атрибуту вложенного объекта
                f"Баланс: {self.balance} руб.")

    def top_up_balance(self, amount):
        """Пополнение баланса"""
        if amount > 0:
            self.balance += amount # изменение атрибута происходит через метод
            return f"Баланс пополнен на {amount} руб. Текущий баланс: {self.balance} руб."
        else:
            raise ValueError("Сумма пополнения должна быть положительной")
            # Пользователь не может просто присвоить balance, должен использовать метод

    def check_balance(self):
        """Проверка баланса"""
        return f"Текущий баланс: {self.balance} руб."


def create_tariff_from_input():
    """Создание тарифного плана с вводом с клавиатуры"""
    print("\n=== Создание тарифного плана ===")
    try:
        name = input("Введите название тарифа: ").strip()
        if not name:
            raise ValueError("Название тарифа не может быть пустым")

        monthly_fee = float(input("Введите абонентскую плату (руб.): "))
        if monthly_fee < 0:
            raise ValueError("Абонентская плата не может быть отрицательной")

        data_limit = float(input("Введите лимит трафика (ГБ): "))
        if data_limit < 0:
            raise ValueError("Лимит трафика не может быть отрицательным")

        call_minutes = int(input("Введите количество минут разговора: "))
        if call_minutes < 0:
            raise ValueError("Количество минут не может быть отрицательным")

        return TariffPlan(name, monthly_fee, data_limit, call_minutes)

    except ValueError as e:
        print(f"Ошибка ввода: {e}")
        return None


def create_subscriber_from_input():
    """Создание абонента с вводом с клавиатуры"""
    print("\n=== Создание абонента ===")
    try:
        phone_number = input("Введите номер телефона: ").strip()
        if not phone_number:
            raise ValueError("Номер телефона не может быть пустым")
        if len(phone_number) < 10:
            raise ValueError("Номер телефона должен содержать минимум 10 символов")

        full_name = input("Введите ФИО абонента: ").strip()
        if not full_name:
            raise ValueError("ФИО абонента не может быть пустым")

        # Проверка, что введено хотя бы имя и фамилия
        name_parts = full_name.split()
        if len(name_parts) < 2:
            raise ValueError("Введите полное ФИО (минимум имя и фамилия)")

        # Создаем тариф, если его нет
        tariff = create_tariff_from_input()
        if tariff is None:
            raise ValueError("Не удалось создать тарифный план")

        balance = float(input("Введите начальный баланс (руб.): "))
        if balance < 0:
            raise ValueError("Баланс не может быть отрицательным")

        return Subscriber(phone_number, full_name, tariff, balance)

    except ValueError as e:
        print(f"Ошибка ввода: {e}")
        return None


def create_support_metric_from_input():
    """Создание метрики поддержки с вводом с клавиатуры"""
    print("\n=== Создание метрики поддержки ===")
    try:
        name = input("Введите название метрики: ").strip()
        if not name:
            raise ValueError("Название метрики не может быть пустым")

        sla = float(input("Введите значение SLA (в %): "))
        if sla < 0 or sla > 100:
            raise ValueError("SLA должно быть в диапазоне от 0 до 100")

        department = input("Введите название отдела: ").strip()
        if not department:
            raise ValueError("Название отдела не может быть пустым")

        return SupportMetric(name, sla, department)

    except ValueError as e:
        print(f"Ошибка ввода: {e}")
        return None


def main():
    """Главная функция для демонстрации работы"""
    print("Добро пожаловать в систему управления телеком-компанией!")

    # Создание абонента
    subscriber = create_subscriber_from_input()
    if subscriber:
        print("\n" + "="*50)
        print("Созданный абонент:")
        print(subscriber)
        print("="*50)

        # Демонстрация работы методов
        print("\nДемонстрация работы методов:")
        try:
            print(subscriber.top_up_balance(500))
            print(subscriber.check_balance())
        except ValueError as e:
            print(f"Ошибка: {e}")

    # Создание метрики поддержки
    metric = create_support_metric_from_input()
    if metric:
        print("\n" + "="*50)
        print("Созданная метрика:")
        print(metric)
        print(f"Оценка производительности: {metric.evaluate_performance()}%")
        print("="*50)

if __name__ == "__main__":
    main()
